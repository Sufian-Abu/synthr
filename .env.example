# Copy to .env and fill in the keys you use. Only the configured providers need a key.
# .env is gitignored — never commit real keys.

# Signs/validates project keys (any random string is fine for local dev)
SYNTHR_SECRET=dev-secret

# Provider API keys (leave blank the ones you don't use)
GEMINI_KEY=
OPENAI_KEY=
XAI_KEY=          # xAI Grok  (keys start with xai-)
GROQ_KEY=         # Groq fast inference (keys start with gsk_)
HF_TOKEN=         # Hugging Face — FREE text-to-image (token at huggingface.co/settings/tokens, keys start hf_)
